# 🌐 Common
FRONTEND_URL=https://troudo.pro
NODE_ENV=production

# 🔐 Auth
JWT_SECRET=your_long_random_jwt_secret_here

# 📧 SMTP (Gmail / Mailtrap / Mail.ru)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password

# 💾 Database (PostgreSQL)
POSTGRES_USER=troudo_admin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=troudo_db

# 💳 Payments (YooKassa)
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_test_or_live_secret
YOOKASSA_WEBHOOK_SECRET=your_webhook_hmac_secret
YOOKASSA_RETURN_URL=https://troudo.pro/dashboard

# 📦 S3 / MinIO (File Storage)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://s3.troudo.pro
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=troudo-files

# 🌐 Monitoring & Domain
DOMAIN_NAME=troudo.pro
