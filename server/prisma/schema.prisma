generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  client
  freelancer
  admin
}

enum DealStatus {
  created
  active
  submitted
  completed
  dispute
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String?
  username       String?  @unique
  avatar         String?  @default("👤")
  balance        Decimal  @default(0) @db.Decimal(12, 2)
  activeRole     Role     @default(client)
  roles          Role[]   @default([client, freelancer])
  bio            String?
  specialization String?
  isVerified            Boolean   @default(false)
  verificationToken     String?   @unique
  verificationExpires   DateTime?
  lastVerificationSent  DateTime?
  lastSeen              DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  projects          Project[]
  kworks            Kwork[]
  offers            Offer[]
  dealsAsClient     Deal[]        @relation("ClientDeals")
  dealsAsFreelancer Deal[]        @relation("FreelancerDeals")
  transactions      Transaction[]
  sentMessages      ChatMessage[]
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  budget      Decimal  @db.Decimal(12, 2)
  category    String
  status      String   @default("open") // open, in_progress, closed
  createdAt   DateTime @default(now())

  clientId String
  client   User     @relation(fields: [clientId], references: [id])
  offers   Offer[]
  deals    Deal[]
}

model Offer {
  id           String   @id @default(uuid())
  price        Decimal  @db.Decimal(12, 2)
  message      String   @db.Text
  createdAt    DateTime @default(now())

  projectId    String
  project      Project @relation(fields: [projectId], references: [id])
  freelancerId String
  freelancer   User    @relation(fields: [freelancerId], references: [id])
}

model Kwork {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  category    String
  createdAt   DateTime @default(now())

  freelancerId String
  freelancer   User   @relation(fields: [freelancerId], references: [id])
}

model Deal {
  id        String     @id @default(uuid())
  amount    Decimal    @db.Decimal(12, 2)
  status    DealStatus @default(created)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id])
  kworkId      String?
  clientId     String
  client       User     @relation("ClientDeals", fields: [clientId], references: [id])
  freelancerId String
  freelancer   User     @relation("FreelancerDeals", fields: [freelancerId], references: [id])
  messages     ChatMessage[]
  
  paymentId     String?
  paymentStatus String?  @default("pending") // pending, succeeded, canceled
}

model ChatMessage {
  id        String   @id @default(uuid())
  text      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id])
  senderId String
  sender   User   @relation(fields: [senderId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  type        String // deposit, withdrawal, payment, refund
  description String? // Added for audit trail
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
